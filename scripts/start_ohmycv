#!/usr/bin/env bash
set -euo pipefail

install=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --install)
      install=true
      shift
      ;;
    -h|--help)
      echo "Usage: scripts/start_ohmycv [--install]" >&2
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: scripts/start_ohmycv [--install]" >&2
      exit 2
      ;;
  esac
done

repo_dir="vendor/oh-my-cv"

if [[ ! -f "$repo_dir/package.json" ]]; then
  echo "Oh My CV repo not found at $repo_dir" >&2
  echo "Expected Renovamen/oh-my-cv to be cloned under resume-agent/vendor/oh-my-cv." >&2
  exit 2
fi

if command -v pnpm >/dev/null 2>&1; then
  pnpm_cmd=(pnpm)
elif command -v corepack >/dev/null 2>&1; then
  pnpm_cmd=(corepack pnpm)
else
  echo "pnpm is required. Install pnpm or enable corepack, then rerun this script." >&2
  exit 127
fi

if [[ "$install" == true ]]; then
  if ! "${pnpm_cmd[@]}" --dir "$repo_dir" install; then
    echo "pnpm install failed. Approving pending dependency build scripts and retrying once..." >&2
    "${pnpm_cmd[@]}" --dir "$repo_dir" approve-builds --all
    "${pnpm_cmd[@]}" --dir "$repo_dir" install
  fi
fi

if [[ ! -d "$repo_dir/node_modules" ]]; then
  echo "Dependencies are not installed yet." >&2
  echo "First run: scripts/start_ohmycv --install" >&2
  exit 2
fi

needs_pkg_build=false
for package_json in "$repo_dir"/packages/*/package.json; do
  pkg_dir="$(dirname "$package_json")"
  if [[ ! -f "$pkg_dir/dist/index.mjs" ]]; then
    needs_pkg_build=true
    break
  fi
done

if [[ "$needs_pkg_build" == true ]]; then
  echo "Building Oh My CV workspace packages..."
  "${pnpm_cmd[@]}" --dir "$repo_dir" build-fast:pkg
fi

echo "Starting local Oh My CV. Use the localhost URL printed by Nuxt."
echo "Import files generated by scripts/export_for_ohmycv from outputs/ohmycv_import/."
exec "${pnpm_cmd[@]}" --dir "$repo_dir" dev
