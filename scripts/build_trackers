#!/usr/bin/env python3
from pathlib import Path
import csv
import re

ROOT = Path(__file__).resolve().parents[1]
APP = ROOT / "trackers" / "applications.yml"
CSV_OUT = ROOT / "trackers" / "application_table.csv"
BOARD_OUT = ROOT / "trackers" / "application_board.md"

FIELDS = [
    "application_id",
    "company",
    "position",
    "platform",
    "priority",
    "fit_score",
    "application_stage",
    "owner_next_action",
    "next_action_date",
    "resume_pdf",
    "interview_pack",
    "record_status",
]


def parse_simple_applications(text: str) -> list[dict[str, str]]:
    records: list[dict[str, str]] = []
    current: dict[str, str] | None = None
    for raw in text.splitlines():
        line = raw.rstrip()
        m_new = re.match(r"\s*-\s*application_id\s*:\s*(.+)", line)
        if m_new:
            if current:
                records.append(current)
            current = {"application_id": clean(m_new.group(1))}
            continue
        if current is None:
            continue
        m_key = re.match(r"\s{2,}([A-Za-z0-9_]+)\s*:\s*(.*)", line)
        if m_key:
            key, value = m_key.groups()
            if key in FIELDS:
                current[key] = clean(value)
    if current:
        records.append(current)
    return records


def clean(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {'"', "'"}:
        return value[1:-1]
    return value


def write_csv(records: list[dict[str, str]]) -> None:
    with CSV_OUT.open("w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=FIELDS)
        writer.writeheader()
        for record in records:
            writer.writerow({field: record.get(field, "") for field in FIELDS})


def write_board(records: list[dict[str, str]]) -> None:
    if not records:
        BOARD_OUT.write_text("# Application Board\n\n当前暂无投递记录。\n", encoding="utf-8")
        return
    groups: dict[str, list[dict[str, str]]] = {}
    for record in records:
        groups.setdefault(record.get("application_stage", "unknown"), []).append(record)
    lines = ["# Application Board", ""]
    for stage in sorted(groups):
        lines.extend([f"## {stage}", ""])
        for record in groups[stage]:
            title = " | ".join(filter(None, [
                record.get("priority", ""),
                record.get("company", ""),
                record.get("position", ""),
                record.get("platform", ""),
                f"fit {record.get('fit_score', '')}" if record.get("fit_score") else "",
            ]))
            lines.append(f"### {title}")
            lines.append("")
            lines.append(f"- Application stage: {record.get('application_stage', '')}")
            lines.append(f"- Record status: {record.get('record_status', '')}")
            lines.append(f"- Next: {record.get('next_action_date', '')} {record.get('owner_next_action', '')}".rstrip())
            if record.get("resume_pdf"):
                lines.append(f"- Resume: {record['resume_pdf']}")
            if record.get("interview_pack"):
                lines.append(f"- Interview: {record['interview_pack']}")
            lines.append("")
    BOARD_OUT.write_text("\n".join(lines), encoding="utf-8")


def main() -> int:
    text = APP.read_text(encoding="utf-8") if APP.exists() else "applications: []"
    records = parse_simple_applications(text)
    write_csv(records)
    write_board(records)
    print(f"Generated {CSV_OUT.relative_to(ROOT)} and {BOARD_OUT.relative_to(ROOT)} with {len(records)} records.")
    return 0

if __name__ == "__main__":
    raise SystemExit(main())
